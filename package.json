{
  "name": "web-wishlist-prisma",
  "version": "1.0.0",
  "description": "Wishlist REST API - Node.js + Express + TypeScript + Prisma + Supabase (+ React/Mantine frontend)",
  "main": "dist/src/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:web": "pnpm --dir web dev",
    "build": "prisma generate && tsc && pnpm --dir web build",
    "build:web": "pnpm --dir web build",
    "start": "node dist/src/server.js",
    "vercel-build": "prisma generate && prisma migrate deploy && pnpm --dir web install --frozen-lockfile && pnpm --dir web build",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "typecheck": "tsc --noEmit && pnpm --dir web typecheck"
  },
  "keywords": [
    "wishlist",
    "express",
    "prisma",
    "supabase",
    "vercel",
    "mantine",
    "react"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
